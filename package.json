{
  "name": "branchlesspay-blockchain",
  "version": "4.0.0",
  "description": "Modular PPOB Infrastructure on Monad",
  "main": "index.js",
  "scripts": {
    "test": "TS_NODE_TRANSPILE_ONLY=true NODE_OPTIONS='--require ts-node/register' hardhat test test/BranchlessPayCore.test.ts test/AgentRegistry.test.ts test/ComplianceReporter.test.ts",
    "coverage": "TS_NODE_TRANSPILE_ONLY=true NODE_OPTIONS='--require ts-node/register' hardhat coverage --testfiles 'test/*.test.ts'",
    "test:hotswap": "node scripts/test-hot-swap.mjs",
    "test:stress": "node scripts/stress-test.mjs",
    "deploy:core": "node scripts/deploy-core.mjs",
    "deploy:pk": "hardhat run scripts/deploy-pk-rules.js --network monad_testnet"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "dotenv": "^16.4.0",
    "ethers": "^6.10.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@openzeppelin/contracts": "^5.0.0",
    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.41",
    "chai": "^4.5.0",
    "hardhat": "^2.19.0",
    "hardhat-gas-reporter": "^1.0.10",
    "solidity-coverage": "^0.8.17",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.9.3"
  }
}
